<view class="check-in-page">
  <view class="map-section" wx:if="{{location && nearestPoint}}">
    <map
      id="checkInMap"
      class="check-in-map"
      latitude="{{nearestPoint.latitude}}"
      longitude="{{nearestPoint.longitude}}"
      scale="{{mapScale}}"
      markers="{{markers}}"
      circles="{{circles}}"
      show-location
      bindmarkertap="onMarkerTap"
    ></map>
    <view class="map-btn-group">
      <view class="map-btn" bindtap="moveToLocation">
        <text>📍 我的位置</text>
      </view>
    </view>
  </view>

  <view class="status-card">
    <view class="status-icon {{canSubmit ? 'active' : ''}} {{actionMode === 'check_out' ? 'checkout' : ''}}">
      <text>{{actionMode === 'check_out' ? '退' : '签'}}</text>
    </view>

    <block wx:if="{{isLoading}}">
      <text class="status-title">定位中...</text>
      <text class="status-desc">正在获取你的位置和签到点信息</text>
    </block>

    <block wx:elif="{{nearestPoint}}">
      <text class="status-tag {{actionMode}}">
        {{actionMode === 'check_out' ? '待签退' : actionMode === 'checked_out' ? '已签退' : '待签到'}}
      </text>
      <text class="status-title">{{nearestPoint.name}}</text>
      <text class="status-desc">{{statusDescription}}</text>

      <text class="status-hint" wx:if="{{actionMode === 'checked_out'}}">
        今日已完成签到，明天可再次签到
      </text>
      <text class="status-hint" wx:elif="{{actionMode === 'check_out' && !canSubmit}}">
        需要回到 {{nearestPoint.radius}}m 范围内才能签退
      </text>
      <text class="status-hint" wx:elif="{{!canSubmit && timeStatus === 'not_started'}}">签到尚未开始</text>
      <text class="status-hint" wx:elif="{{!canSubmit && timeStatus === 'ended'}}">签到已结束</text>
      <text class="status-hint" wx:elif="{{!canSubmit}}">需要在 {{nearestPoint.radius}}m 范围内才能签到</text>

      <text class="time-range" wx:if="{{timeRangeText && actionMode === 'check_in'}}">签到时间：{{timeRangeText}}</text>
      <text class="time-range" wx:if="{{activeRecord && actionMode === 'check_out'}}">签到时间：{{activeRecord.check_in_label}}</text>

      <button
        class="check-in-btn {{canSubmit ? 'active' : 'disabled'}} {{actionMode === 'check_out' ? 'checkout' : ''}}"
        bindtap="onSubmitAction"
        disabled="{{!canSubmit || isSubmitting}}"
      >
        {{isSubmitting ? (actionMode === 'check_out' ? '签退中...' : '签到中...') : actionButtonText}}
      </button>
    </block>

    <block wx:else>
      <text class="status-title">未找到签到点</text>
      <text class="status-desc">附近没有可用的签到点</text>
    </block>

    <view class="refresh-btn" bindtap="onRefreshLocation">
      <text>刷新位置</text>
    </view>
  </view>

  <view class="records-card">
    <view class="card-header">
      <text class="card-title">本月签到记录</text>
      <text class="card-count">{{monthlyCount}} 次</text>
    </view>

    <view class="record-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-main">
          <view class="record-top">
            <text class="record-date">{{item.date_label}}</text>
            <text class="record-status {{item.is_checked_out ? 'done' : 'pending'}}">
              {{item.is_checked_out ? '已签退' : '待签退'}}
            </text>
          </view>
          <text class="record-point">{{item.point_name}}</text>
          <text class="record-meta">签到：{{item.check_in_label}}</text>
          <text class="record-meta">签退：{{item.check_out_label}}</text>
          <text class="record-meta">时长：{{item.duration_label}}</text>
        </view>
      </view>

      <view class="empty" wx:if="{{records.length === 0}}">
        <text>暂无签到记录</text>
      </view>
    </view>
  </view>
</view>
