<view class="check-in-page">
  <!-- 地图显示 -->
  <view class="map-section" wx:if="{{location && nearestPoint}}">
    <map
      id="checkInMap"
      class="check-in-map"
      latitude="{{nearestPoint.latitude}}"
      longitude="{{nearestPoint.longitude}}"
      scale="{{mapScale}}"
      markers="{{markers}}"
      circles="{{circles}}"
      show-location
      bindmarkertap="onMarkerTap"
    ></map>
    <view class="map-btn-group">
      <view class="map-btn" bindtap="moveToLocation">
        <text>📍 我的位置</text>
      </view>
    </view>
  </view>

  <!-- 签到状态卡片 -->
  <view class="status-card">
    <view class="status-icon {{canCheckIn ? 'active' : ''}}">📍</view>

    <block wx:if="{{isLoading}}">
      <text class="status-title">定位中...</text>
      <text class="status-desc">正在获取您的位置信息</text>
    </block>
    <block wx:elif="{{nearestPoint}}">
      <text class="status-title">{{nearestPoint.name}}</text>
      <text class="status-desc">当前位置距离签到点 {{distance}}m</text>
      <text class="status-hint" wx:if="{{!canCheckIn && timeStatus === 'not_started'}}">签到尚未开始</text>
      <text class="status-hint" wx:elif="{{!canCheckIn && timeStatus === 'ended'}}">签到已结束</text>
      <text class="status-hint" wx:elif="{{!canCheckIn}}">需要在{{nearestPoint.radius}}m范围内才能签到</text>
      <text class="time-range" wx:if="{{timeRangeText}}">签到时间：{{timeRangeText}}</text>

      <button
        class="check-in-btn {{canCheckIn ? 'active' : 'disabled'}}"
        bindtap="onCheckIn"
        disabled="{{!canCheckIn || isCheckingIn}}"
      >
        {{isCheckingIn ? '签到中...' : (canCheckIn ? '立即签到' : timeStatus === 'not_started' ? '未到时间' : timeStatus === 'ended' ? '已结束' : '距离过远')}}
      </button>
    </block>
    <block wx:else>
      <text class="status-title">未找到签到点</text>
      <text class="status-desc">附近没有可用的签到点</text>
    </block>

    <view class="refresh-btn" bindtap="onRefreshLocation">
      <text>🔄 刷新位置</text>
    </view>
  </view>

  <!-- 签到记录 -->
  <view class="records-card">
    <view class="card-header">
      <text class="card-title">本月签到记录</text>
      <text class="card-count">{{monthlyCount}}次</text>
    </view>

    <view class="record-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-info">
          <text class="record-date">{{item.date_label}}</text>
          <text class="record-point">{{item.point_name}}</text>
        </view>
        <text class="record-time">{{item.time_label}} 已签到</text>
      </view>

      <view class="empty" wx:if="{{records.length === 0}}">
        <text>暂无签到记录</text>
      </view>
    </view>
  </view>
</view>
