.check-in-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 24rpx;
}

.map-section {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.check-in-map {
  width: 100%;
  height: 100%;
}

.map-btn-group {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
}

.map-btn {
  background: #ffffff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #333333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.status-card {
  margin: 24rpx;
  padding: 48rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.status-icon {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 28rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e5e7eb, #d1d5db);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4b5563;
  font-size: 52rpx;
  font-weight: 700;
}

.status-icon.active {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
  color: #047857;
}

.status-icon.checkout {
  background: linear-gradient(135deg, #ffedd5, #fdba74);
  color: #c2410c;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 48rpx;
  margin-bottom: 18rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-tag.check_in {
  background: #ecfdf5;
  color: #047857;
}

.status-tag.check_out {
  background: #fff7ed;
  color: #c2410c;
}

.status-tag.checked_out {
  background: #eff6ff;
  color: #1d4ed8;
}

.status-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.status-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.status-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #f59e0b;
}

.time-range {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.check-in-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 40rpx;
  border: none;
  border-radius: 28rpx;
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0;
  line-height: 96rpx;
  text-align: center;
}

.check-in-btn.active {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(16, 185, 129, 0.35);
}

.check-in-btn.checkout.active {
  background: linear-gradient(135deg, #f97316, #ea580c);
  box-shadow: 0 8rpx 28rpx rgba(249, 115, 22, 0.28);
}

.check-in-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.refresh-btn {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #9ca3af;
}

.records-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.card-count {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: 500;
}

.record-list {
  padding: 0 36rpx 36rpx;
}

.record-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.record-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.record-status.done {
  background: #ecfdf5;
  color: #047857;
}

.record-status.pending {
  background: #fff7ed;
  color: #c2410c;
}

.record-point {
  font-size: 24rpx;
  color: #6b7280;
}

.record-meta {
  font-size: 24rpx;
  color: #9ca3af;
}

.empty {
  padding: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
}
