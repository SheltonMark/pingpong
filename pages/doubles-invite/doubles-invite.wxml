<view class="invite-page">
  <view class="invite-card" wx:if="{{!isLoading && invitation}}">
    <view class="invite-icon">🏓</view>
    <text class="invite-title">{{invitation.inviter_name || '搭档'}} 邀请你一起报名</text>

    <view class="event-info-card" wx:if="{{event}}">
      <text class="event-name">{{event.title}}</text>
      <text class="event-meta">双打赛事{{event.location ? ' · ' + event.location : ''}}</text>
    </view>

    <view class="action-area" wx:if="{{invitationState === 'pending_guest'}}">
      <text class="tip-text">你还没有登录，请先注册或登录后再处理邀请。</text>
      <button class="action-btn primary" bindtap="onGoRegister">去注册 / 登录</button>
    </view>

    <view class="action-area" wx:elif="{{invitationState === 'pending_targeted'}}">
      <text class="tip-text">确认后你会直接和对方组成混双搭档；如果拒绝，双方会回到等待配对列表。</text>
      <view class="action-row">
        <button class="action-btn secondary" bindtap="onRespond" data-action="reject" disabled="{{isSubmitting}}">
          {{isSubmitting ? '处理中...' : '拒绝邀请'}}
        </button>
        <button class="action-btn primary" bindtap="onRespond" data-action="accept" disabled="{{isSubmitting}}">
          {{isSubmitting ? '处理中...' : '确认搭档'}}
        </button>
      </view>
    </view>

    <view class="action-area" wx:elif="{{invitationState === 'pending_open_link'}}">
      <text class="tip-text">这是分享邀请链接。确认后你会直接和对方组成混双搭档；如果不参加，直接关闭页面即可。</text>
      <button class="action-btn primary" bindtap="onRespond" data-action="accept" disabled="{{isSubmitting}}">
        {{isSubmitting ? '处理中...' : '确认搭档'}}
      </button>
    </view>

    <view class="action-area" wx:elif="{{invitationState === 'pending_blocked'}}">
      <text class="tip-text">{{invitation.response_block_reason || '当前账号不能处理该邀请'}}</text>
    </view>

    <view class="action-area success" wx:elif="{{invitationState === 'joined'}}">
      <view class="success-icon">✓</view>
      <text class="tip-text">你已确认搭档，双打报名已完成。</text>
    </view>

    <view class="action-area success" wx:elif="{{invitationState === 'rejected_self'}}">
      <view class="success-icon muted">已</view>
      <text class="tip-text">你已拒绝本次邀请，双方已回到等待配对列表，可重新发起配对。</text>
    </view>

    <view class="action-area" wx:elif="{{invitationState === 'accepted_other'}}">
      <text class="tip-text">这条邀请已经被其他人处理，当前链接不能重复使用。</text>
    </view>

    <view class="action-area" wx:elif="{{invitationState === 'rejected_other'}}">
      <text class="tip-text">这条邀请已经被处理，双方已返回等待配对列表。</text>
    </view>

    <view class="action-area" wx:elif="{{invitationState === 'cancelled'}}">
      <text class="tip-text">邀请方已取消这条邀请，当前链接已失效。</text>
    </view>

    <view class="action-area" wx:elif="{{invitationState === 'expired'}}">
      <text class="tip-text">这条邀请已过期，请让对方重新发起邀请。</text>
    </view>
  </view>

  <view class="invite-card error" wx:elif="{{!isLoading}}">
    <view class="invite-icon">!</view>
    <text class="invite-title">邀请不可用</text>
    <text class="tip-text">{{errorMsg || '邀请不存在或已失效'}}</text>
  </view>

  <view class="loading" wx:else>加载中...</view>
</view>
