.invite-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.invite-card {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 56rpx 40rpx;
  box-sizing: border-box;
  text-align: center;
  box-shadow: 0 6rpx 28rpx rgba(15, 23, 42, 0.08);
}

.invite-card.error {
  padding-top: 72rpx;
  padding-bottom: 72rpx;
}

.invite-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.invite-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #111827;
}

.event-info-card {
  background: #f9fafb;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin: 36rpx 0;
}

.event-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
}

.event-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.action-area {
  margin-top: 12rpx;
}

.action-area.success {
  padding-top: 8rpx;
}

.tip-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6b7280;
  margin-bottom: 28rpx;
}

.success-icon {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 16rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ecfdf5;
  color: #047857;
  font-size: 40rpx;
  font-weight: 700;
}

.success-icon.muted {
  background: #f3f4f6;
  color: #6b7280;
  font-size: 28rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border: none;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #ff8a00, #ff6b00);
  color: #ffffff;
}

.action-btn.secondary {
  background: #f3f4f6;
  color: #4b5563;
}

.action-btn[disabled] {
  opacity: 0.5;
}

.loading {
  text-align: center;
  padding: 80rpx;
  font-size: 28rpx;
  color: #9ca3af;
}
