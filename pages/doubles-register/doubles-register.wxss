.register-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.event-card,
.mode-card,
.partner-card,
.wait-tip,
.invite-card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.event-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.event-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.event-info {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #9ca3af;
}

.mode-card {
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: block;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.mode-item {
  display: flex;
  gap: 20rpx;
  align-items: center;
  padding: 32rpx;
  border: 4rpx solid #e5e7eb;
  border-radius: 24rpx;
}

.mode-item.active {
  border-color: #ff6b00;
  background: #fff5eb;
}

.mode-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mode-radio.checked {
  background: #ff6b00;
  border-color: #ff6b00;
  color: #ffffff;
  font-size: 24rpx;
}

.mode-content {
  flex: 1;
}

.mode-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.mode-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.invite-card,
.partner-card {
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-header .card-title {
  margin-bottom: 0;
}

.card-count {
  font-size: 24rpx;
  color: #ff6b00;
}

.invite-body {
  display: flex;
  gap: 24rpx;
  align-items: center;
  padding: 32rpx 36rpx 40rpx;
}

.invite-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ff8a00, #ff6b00);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.invite-main {
  flex: 1;
}

.invite-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.invite-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.partner-list {
  padding: 0 36rpx 36rpx;
}

.partner-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-top: 20rpx;
  background: #f9fafb;
  border-radius: 24rpx;
  border: 4rpx solid transparent;
}

.partner-item.selected {
  background: #fff5eb;
  border-color: #ff6b00;
}

.partner-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.partner-info {
  flex: 1;
  margin-left: 24rpx;
}

.partner-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.partner-college {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.partner-check {
  color: #ff6b00;
  font-size: 36rpx;
}

.empty-tip {
  padding: 40rpx;
  text-align: center;
  font-size: 26rpx;
  color: #9ca3af;
}

.wait-tip {
  padding: 60rpx 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.tip-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
}

.tip-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.tip-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: #6b7280;
}

.submit-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 48rpx;
  height: 96rpx;
  border: none;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ff6b00, #e55d00);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.35);
}

.submit-btn[disabled] {
  opacity: 0.5;
}

.share-submit-btn {
  background: linear-gradient(135deg, #ff8a00, #ff6b00);
}

.loading {
  padding: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
}
