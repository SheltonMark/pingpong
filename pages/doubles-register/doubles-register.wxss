.register-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.event-card,
.mode-card,
.submode-card,
.panel-card,
.status-card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.event-card {
  padding: 32rpx;
}

.event-name,
.status-title,
.wait-title,
.wechat-title,
.pending-partner-name,
.partner-name {
  display: block;
  color: #1a1a1a;
}

.event-name,
.status-title,
.wait-title,
.wechat-title {
  font-size: 32rpx;
  font-weight: 600;
}

.event-info,
.status-desc,
.mode-desc,
.partner-meta,
.wechat-desc,
.helper-tip,
.wait-desc,
.pending-partner-desc {
  color: #6b7280;
  line-height: 1.6;
}

.event-info {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
}

.mode-card,
.submode-card {
  padding: 32rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 24rpx;
}

.mode-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  border: 4rpx solid #e5e7eb;
  border-radius: 24rpx;
}

.mode-item.active {
  border-color: #ff6b00;
  background: #fff5eb;
}

.mode-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  flex-shrink: 0;
}

.mode-radio.checked {
  border-color: #ff6b00;
  background: #ff6b00;
}

.mode-content {
  flex: 1;
}

.mode-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.mode-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.submode-tabs {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: #f3f4f6;
}

.submode-tab {
  flex: 1;
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #6b7280;
}

.submode-tab.active {
  background: #ffffff;
  color: #ff6b00;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-count {
  font-size: 24rpx;
  color: #ff6b00;
}

.partner-list {
  padding: 8rpx 32rpx 32rpx;
}

.partner-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  background: #f9fafb;
  border: 4rpx solid transparent;
  border-radius: 24rpx;
}

.partner-item.selected {
  background: #fff5eb;
  border-color: #ff6b00;
}

.partner-avatar,
.invite-partner-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  background: #e5e7eb;
}

.partner-info,
.pending-partner-main,
.wechat-main {
  flex: 1;
}

.partner-name {
  font-size: 28rpx;
  font-weight: 600;
}

.partner-meta,
.pending-partner-desc,
.wechat-desc,
.helper-tip,
.wait-desc,
.status-desc {
  font-size: 24rpx;
}

.partner-meta {
  display: block;
  margin-top: 6rpx;
}

.partner-check {
  color: #ff6b00;
  font-size: 36rpx;
  font-weight: 700;
}

.pending-partner-card,
.wechat-card,
.wait-content,
.status-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
}

.pending-partner-avatar,
.wechat-icon,
.wait-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.wechat-icon,
.wait-icon {
  background: linear-gradient(135deg, #ff8a00, #ff6b00);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.pending-partner-name,
.wechat-title {
  font-size: 30rpx;
  font-weight: 600;
}

.helper-tip {
  display: block;
  padding: 0 32rpx 32rpx;
}

.wait-card .card-header {
  border-bottom: none;
  padding-bottom: 0;
}

.wait-content {
  flex-direction: column;
  align-items: flex-start;
  padding-top: 24rpx;
}

.status-card.confirmed {
  background: linear-gradient(180deg, #fff7ed, #ffffff);
}

.status-card {
  align-items: flex-start;
  flex-direction: column;
}

.empty-tip {
  padding: 40rpx 32rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #9ca3af;
}

.submit-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 48rpx;
  height: 96rpx;
  border: none;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ff6b00, #e55d00);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.35);
}

.submit-btn[disabled] {
  opacity: 0.5;
}

.loading {
  padding: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
}
