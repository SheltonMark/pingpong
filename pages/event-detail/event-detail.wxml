<!-- pages/event-detail/event-detail.wxml -->
<view class="event-detail-page" wx:if="{{!loading}}">
  <!-- 头部信息 -->
  <view class="event-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="event-type-tag {{event.event_type}}">
        {{event.event_type === 'singles' ? '单打' : event.event_type === 'doubles' ? '双打' : '团体'}}
      </view>
      <view class="event-title">{{event.title}}</view>
      <view class="event-status-tag {{event.status}}">
        {{event.status === 'registration' ? '报名中' : event.status === 'pending_start' ? '待开始' : event.status === 'ongoing' ? '进行中' : '已结束'}}
      </view>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'info' ? 'active' : ''}}" data-tab="info" bindtap="onTabChange">赛事信息</view>
    <view class="tab-item {{currentTab === 'players' ? 'active' : ''}}" data-tab="players" bindtap="onTabChange">
      {{event.event_type === 'team' ? '参赛队伍' : '参赛选手'}} ({{event.event_type === 'team' ? (teamCount || 0) : event.event_type === 'doubles' ? (doublesPairs.length + '组' + (waitingPlayers.length > 0 ? '+' + waitingPlayers.length : '')) : registrations.length}})
    </view>
    <view class="tab-item {{currentTab === 'matches' ? 'active' : ''}}" data-tab="matches" bindtap="onTabChange">对阵表</view>
  </view>

  <!-- 赛事信息 -->
  <view class="tab-content" wx:if="{{currentTab === 'info'}}">
    <view class="info-card">
      <view class="info-row">
        <text class="info-label">📅 比赛时间</text>
        <text class="info-value">{{event.event_start_display || event.event_start}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">📍 比赛地点</text>
        <text class="info-value">{{event.location}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">🏆 赛制</text>
        <text class="info-value">{{event.event_format === 'knockout' ? '淘汰赛' : event.event_format === 'round_robin' ? '循环赛' : '小组+淘汰'}} · {{event.best_of}}局{{event.games_to_win || (event.best_of == 3 ? '2' : event.best_of == 5 ? '3' : '4')}}胜</text>
      </view>
      <view class="info-row" wx:if="{{event.event_type === 'singles'}}">
        <text class="info-label">📊 计入积分</text>
        <text class="info-value">{{event.counts_for_ranking ? '是' : '否'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">{{event.event_type === 'team' ? '🏅 参赛队伍' : '👤 报名人数'}}</text>
        <text class="info-value">{{event.event_type === 'team' ? (teamCount || 0) : registrations.length}}/{{event.max_participants}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">⏰ 报名截止</text>
        <text class="info-value">{{event.registration_end_display || event.registration_end}}</text>
      </view>
    </view>

    <view class="desc-card" wx:if="{{event.description || (event.descriptionImages && event.descriptionImages.length > 0)}}">
      <view class="card-title">赛事说明</view>
      <rich-text class="desc-content" nodes="{{event.description}}" wx:if="{{event.description}}"></rich-text>
      <view class="desc-images" wx:if="{{event.descriptionImages && event.descriptionImages.length > 0}}">
        <image
          wx:for="{{event.descriptionImages}}"
          wx:key="index"
          class="desc-image"
          src="{{item}}"
          mode="widthFix"
          bindtap="onPreviewImage"
          data-url="{{item}}"
        />
      </view>
    </view>

    <!-- 团体赛领队申请 -->
    <view class="captain-card" wx:if="{{event.event_type === 'team'}}">
      <view class="card-title">领队申请</view>
      <view class="captain-content">
        <view wx:if="{{isCaptain}}" class="captain-status approved">
          <text class="status-icon">✓</text>
          <text>您是该赛事的领队</text>
        </view>
        <view wx:elif="{{captainStatus === 'pending'}}" class="captain-status pending">
          <text class="status-icon">⏳</text>
          <text>领队申请审批中</text>
        </view>
        <view wx:elif="{{captainStatus === 'rejected'}}" class="captain-status rejected">
          <text class="status-icon">✗</text>
          <text>申请被拒绝，可重新申请</text>
          <button class="apply-btn small" bindtap="onApplyCaptain">重新申请</button>
        </view>
        <view wx:else class="captain-tip">
          <text>领队可以组建队伍并管理队员报名</text>
          <button class="apply-btn" bindtap="onApplyCaptain">申请成为领队</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 参赛选手 -->
  <view class="tab-content" wx:if="{{currentTab === 'players'}}">
    <!-- 双打赛事：配对显示 -->
    <block wx:if="{{event.event_type === 'doubles'}}">
      <!-- 已配对 -->
      <view wx:if="{{doublesPairs.length > 0}}">
        <view class="section-title">已配对 ({{doublesPairs.length}}组)</view>
        <view class="doubles-pair-card" wx:for="{{doublesPairs}}" wx:key="id">
          <view class="pair-status-tag {{item.status}}">
            {{item.status === 'confirmed' ? '已确认' : '待确认'}}
          </view>
          <view class="pair-players">
            <view class="pair-player">
              <image class="pair-avatar" src="{{item.player1.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
              <text class="pair-name">{{item.player1.name}}</text>
              <text class="pair-college">{{item.player1.school_name || ''}}{{item.player1.college_name ? ' · ' + item.player1.college_name : ''}}</text>
            </view>
            <view class="pair-connector">&</view>
            <view class="pair-player">
              <image class="pair-avatar" src="{{item.player2.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
              <text class="pair-name">{{item.player2.name}}</text>
              <text class="pair-college">{{item.player2.school_name || ''}}{{item.player2.college_name ? ' · ' + item.player2.college_name : ''}}</text>
            </view>
          </view>
        </view>
      </view>
      <!-- 等待配对 -->
      <view wx:if="{{waitingPlayers.length > 0}}">
        <view class="section-title">等待配对 ({{waitingPlayers.length}}人)</view>
        <view class="player-list">
          <view class="player-item" wx:for="{{waitingPlayers}}" wx:key="id">
            <image class="player-avatar" src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
            <view class="player-info">
              <text class="player-name">{{item.name}}</text>
              <text class="player-college">{{item.school_name}}{{item.college_name ? ' · ' + item.college_name : ''}}</text>
            </view>
            <view class="waiting-tag">等待中</view>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{doublesPairs.length === 0 && waitingPlayers.length === 0}}">暂无报名</view>
    </block>
    <!-- 单打/团体：原有列表 -->
    <block wx:else>
      <view class="player-list" wx:if="{{registrations.length > 0}}">
        <view class="player-item" wx:for="{{registrations}}" wx:key="id">
          <view class="player-rank">{{index + 1}}</view>
          <image class="player-avatar" src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="player-info">
            <text class="player-name">{{item.name}}</text>
            <text class="player-college">{{item.school_name}}{{item.college_name ? ' · ' + item.college_name : ''}}</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>暂无报名</view>
    </block>
  </view>

  <!-- 对阵表 -->
  <view class="tab-content" wx:if="{{currentTab === 'matches'}}">
    <view class="match-list" wx:if="{{matches.length > 0}}">
      <view class="match-item" wx:for="{{matches}}" wx:key="id">
        <view class="match-round">第{{item.round}}轮 · 第{{item.match_order}}场</view>
        <view class="match-players">
          <view class="player-side">
            <text class="player">{{item.player1_name || '待定'}}</text>
            <text class="score" wx:if="{{item.status === 'finished'}}">{{item.player1_games}}</text>
          </view>
          <text class="vs">VS</text>
          <view class="player-side">
            <text class="score" wx:if="{{item.status === 'finished'}}">{{item.player2_games}}</text>
            <text class="player">{{item.player2_name || '待定'}}</text>
          </view>
        </view>
        <view class="match-status {{item.status}}">
          {{item.status === 'finished' ? '已结束' : item.status === 'ongoing' ? '进行中' : '待进行'}}
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>对阵表尚未生成</view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-action" wx:if="{{event.status === 'registration'}}">
    <!-- 单打：直接报名 -->
    <block wx:if="{{event.event_type === 'singles'}}">
      <button class="register-btn" wx:if="{{!isRegistered}}" bindtap="onRegister">立即报名</button>
      <button class="cancel-btn" wx:else bindtap="onCancelRegister">取消报名</button>
    </block>
    <!-- 双打：报名并选择搭档 -->
    <block wx:elif="{{event.event_type === 'doubles'}}">
      <button class="register-btn" wx:if="{{!isRegistered}}" bindtap="onRegisterDoubles">报名双打</button>
      <button class="cancel-btn" wx:else bindtap="onCancelRegister">取消报名</button>
    </block>
    <!-- 团体赛：只有领队可以报名队伍，普通用户不能直接报名 -->
    <block wx:elif="{{event.event_type === 'team'}}">
      <button class="register-btn" wx:if="{{isCaptain && !hasTeamRegistered}}" bindtap="onRegisterTeam">报名队伍</button>
      <view class="team-tip" wx:elif="{{!isCaptain}}">
        <text>团体赛需要先申请成为领队，再组建队伍报名</text>
      </view>
      <button class="cancel-btn" wx:elif="{{hasTeamRegistered}}" bindtap="onCancelTeamRegister">取消队伍报名</button>
    </block>
  </view>
</view>

<!-- 加载中 -->
<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
