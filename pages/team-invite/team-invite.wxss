.invite-page {
  min-height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.invite-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.invite-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.invite-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.team-name-display {
  font-size: 30rpx;
  color: #FF6B00;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.event-info-card {
  background: #F9FAFB;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 40rpx;
}

.event-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 8rpx;
}

.event-meta {
  font-size: 24rpx;
  color: #9CA3AF;
}

.action-area {
  margin-top: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 24rpx;
}

.success-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ECFDF5;
  color: #059669;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B00, #E55D00);
  color: #fff;
}

.action-btn[disabled] {
  opacity: 0.5;
}

.loading {
  text-align: center;
  padding: 80rpx;
  color: #9CA3AF;
  font-size: 28rpx;
}
