<view class="register-page" wx:if="{{event}}">
  <!-- 赛事信息 -->
  <view class="event-card">
    <text class="event-name">{{event.title}}</text>
    <text class="event-info">团体赛 · {{event.format_label}}</text>
  </view>

  <!-- 队伍名称 -->
  <view class="team-card">
    <view class="card-header">
      <text class="card-title">队伍名称</text>
    </view>
    <input
      class="team-name-input"
      placeholder="请输入队伍名称"
      value="{{teamName}}"
      bindinput="onTeamNameInput"
      disabled="{{hasExistingTeam}}"
    />
  </view>

  <!-- 队员配置 -->
  <view class="team-card">
    <view class="card-header">
      <text class="card-title">队员配置</text>
      <text class="card-subtitle">点击成员可标记单打（最多3人）</text>
    </view>
    <view class="team-list">
      <view
        class="team-slot {{item.status}} {{item.isSingles ? 'singles-marked' : ''}}"
        wx:for="{{teamSlots}}"
        wx:key="index"
      >
        <!-- 已有成员 -->
        <block wx:if="{{item.user}}">
          <view class="slot-main" bindtap="onToggleSingles" data-index="{{index}}">
            <view class="slot-avatar">{{item.isLeader ? '😎' : '🧑'}}</view>
            <view class="slot-info">
              <text class="slot-name">{{item.user.name}}{{item.isLeader ? '（你）' : ''}}</text>
              <text class="slot-position">{{item.isLeader ? '领队 · ' : ''}}{{item.position}}</text>
            </view>
            <view class="slot-tags">
              <text class="singles-tag" wx:if="{{item.isSingles}}">单打</text>
              <text class="slot-status {{item.status}}">
                {{item.status === 'confirmed' ? '已确认' : '待确认'}}
              </text>
            </view>
          </view>
        </block>

        <!-- 空位 -->
        <block wx:else>
          <view class="slot-avatar empty">+</view>
          <view class="slot-info">
            <text class="slot-position-empty">{{item.position}} - 待邀请</text>
          </view>
          <button class="invite-btn" open-type="share">分享邀请</button>
        </block>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions">
    <button
      class="submit-btn"
      bindtap="onSubmit"
      disabled="{{isSubmitting}}"
      wx:if="{{!hasExistingTeam}}"
    >
      {{isSubmitting ? '提交中...' : '提交报名'}}
    </button>
    <button
      class="submit-btn"
      bindtap="saveSinglesMarks"
      wx:else
    >
      保存单打标记
    </button>
  </view>
</view>

<view class="loading" wx:if="{{isLoading}}">加载中...</view>
