<view class="register-page" wx:if="{{event && !isLoading}}">
  <view class="event-card">
    <text class="event-name">{{event.title}}</text>
    <text class="event-info">团体赛报名</text>
    <text class="event-rule">{{ruleText}}</text>
  </view>

  <view class="team-card">
    <view class="card-header">
      <text class="card-title">队伍信息</text>
      <text class="status-tag submitted" wx:if="{{submitted}}">已正式提交</text>
      <text class="status-tag draft" wx:else>草稿中</text>
    </view>

    <view class="form-row">
      <text class="form-label">队伍名称</text>
      <input
        class="team-name-input"
        placeholder="请先填写队伍名称，再邀请队友"
        value="{{teamName}}"
        bindinput="onTeamNameInput"
        bindblur="onTeamNameBlur"
        disabled="{{submitted || !canEdit}}"
      />
    </view>

    <view class="form-row switch-row">
      <view>
        <text class="form-label">领队是否参赛</text>
        <text class="form-tip">参赛则计入人数和性别统计；不参赛则不计入</text>
      </view>
      <switch
        color="#FF6B00"
        checked="{{leaderParticipates}}"
        disabled="{{submitted || !canEdit}}"
        bindchange="onLeaderParticipatingChange"
      />
    </view>

    <view class="summary-grid">
      <view class="summary-item">
        <text class="summary-label">已加入队员</text>
        <text class="summary-value">{{actualPlayerCount}} / {{config.maxTeamPlayers}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">待确认邀请</text>
        <text class="summary-value">{{pendingInvitationCount}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">男 / 女</text>
        <text class="summary-value">{{maleCount}} / {{femaleCount}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">项目分配</text>
        <text class="summary-value">{{totalProjectSlots ? assignedProjectSlots + ' / ' + totalProjectSlots : '未配置'}}</text>
      </view>
    </view>

  </view>

  <view class="team-card">
    <view class="card-header">
      <text class="card-title">邀请队友</text>
      <text class="card-subtitle">每新增一条邀请，会先占用 1 个名额</text>
    </view>

    <view class="invite-panel">
      <text class="invite-tip" wx:if="{{!hasTeamName}}">请先填写并保存队伍名称，再创建邀请。</text>
      <text class="invite-tip" wx:elif="{{occupiedSlots >= config.maxTeamPlayers}}">当前名额已满，请先删除队员或取消邀请后再继续。</text>
      <text class="invite-tip" wx:else>被接受的邀请会进入队员列表；被拒绝、取消或移除后，名额会自动释放。</text>

      <button
        wx:if="{{canEdit}}"
        class="invite-create-btn"
        bindtap="onCreateInvitation"
        disabled="{{submitted || !hasTeamName || occupiedSlots >= config.maxTeamPlayers || isCreatingInvitation}}"
      >
        {{isCreatingInvitation ? '创建中...' : '新增邀请'}}
      </button>
    </view>
  </view>

  <view class="team-card">
    <view class="card-header">
      <text class="card-title">已加入队员</text>
      <text class="card-subtitle">未正式提交前，可删除领队外的队员，可长按队员名字删除</text>
    </view>

    <view class="member-list" wx:if="{{members.length}}">
      <view
        class="member-item"
        wx:for="{{members}}"
        wx:key="user_id"
        bindlongpress="onRemoveMember"
        data-member-id="{{canEdit && !submitted && !item.isLeader ? item.user_id : ''}}"
      >
        <image class="member-avatar" src="{{item.avatar_url || '/assets/default-avatar.png'}}" mode="aspectFill" />
        <view class="member-main">
          <view class="member-title-row">
            <text class="member-name">{{item.name}}</text>
            <text class="mini-tag leader" wx:if="{{item.isLeader}}">领队</text>
            <text class="mini-tag warning" wx:if="{{item.isLeader && !item.isParticipating}}">不参赛</text>
            <text class="mini-tag project-tag men-singles" wx:for="{{item.projects}}" wx:for-item="project" wx:key="project" wx:if="{{project === 'men_singles'}}">男单</text>
            <text class="mini-tag project-tag women-singles" wx:for="{{item.projects}}" wx:for-item="project" wx:key="project" wx:if="{{project === 'women_singles'}}">女单</text>
            <text class="mini-tag project-tag men-doubles" wx:for="{{item.projects}}" wx:for-item="project" wx:key="project" wx:if="{{project === 'men_doubles'}}">男双</text>
            <text class="mini-tag project-tag women-doubles" wx:for="{{item.projects}}" wx:for-item="project" wx:key="project" wx:if="{{project === 'women_doubles'}}">女双</text>
            <text class="mini-tag project-tag mixed-doubles" wx:for="{{item.projects}}" wx:for-item="project" wx:key="project" wx:if="{{project === 'mixed_doubles'}}">混双</text>
          </view>
          <view class="member-info-row">
            <text class="member-info-item">{{item.gender === 'male' ? '男' : '女'}}</text>
            <text class="member-info-item">{{item.school_name}}</text>
            <text class="member-info-item" wx:if="{{item.college_name}}">{{item.college_name}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>当前还没有队员</view>
  </view>

  <view class="team-card">
    <view class="card-header">
      <text class="card-title">邀请记录</text>
      <text class="card-subtitle">保留全部状态，方便查看接受、拒绝和移除结果</text>
    </view>

    <view class="pending-list" wx:if="{{invitations.length}}">
      <view class="pending-item pending-item-compact" wx:for="{{invitations}}" wx:key="id" wx:if="{{item.is_pending}}">
        <view class="invite-avatar placeholder">
          <text class="invite-avatar-text">{{index + 1}}</text>
        </view>
        <view class="pending-inline-actions" wx:if="{{canEdit}}">
          <button class="small-btn pending-inline-btn" open-type="share" data-token="{{item.invite_token}}">分享邀请</button>
          <button class="small-btn danger pending-inline-btn" bindtap="onCancelInvitation" data-invitation-id="{{item.id}}">取消邀请</button>
        </view>
        <view class="pending-main" wx:else>
          <text class="pending-name">邀请编号 {{index + 1}}</text>
        </view>
        <text class="invite-status-tag {{item.status}} pending-inline-status">{{item.status_text}}</text>
      </view>

      <view class="pending-item" wx:for="{{invitations}}" wx:key="id" wx:if="{{!item.is_pending}}">
        <image
          class="member-avatar"
          wx:if="{{item.is_registered}}"
          src="{{item.invitee_avatar_url || '/assets/default-avatar.png'}}"
          mode="aspectFill"
        />
        <view class="invite-avatar placeholder" wx:else>
          <text class="invite-avatar-text">{{index + 1}}</text>
        </view>

        <view class="pending-main">
          <view class="invitation-title-row">
            <text class="pending-name">{{item.display_name}}</text>
            <text class="invite-status-tag {{item.status}}">{{item.status_text}}</text>
          </view>

          <view class="member-info-row" wx:if="{{item.is_registered}}">
            <text class="member-info-item" wx:if="{{item.invitee_gender}}">{{item.invitee_gender === 'male' ? '男' : item.invitee_gender === 'female' ? '女' : '未知'}}</text>
            <text class="member-info-item" wx:if="{{item.invitee_school_name}}">{{item.invitee_school_name}}</text>
            <text class="member-info-item" wx:if="{{item.invitee_college_name}}">{{item.invitee_college_name}}</text>
          </view>

          <text class="pending-meta" wx:if="{{item.status_description}}">{{item.status_description}}</text>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:else>当前还没有邀请记录</view>
  </view>

  <view class="team-card" wx:if="{{projectConfig && projectConfig.projects}}">
    <view class="card-header">
      <text class="card-title">项目分配</text>
      <text class="card-subtitle">为每个项目指定参赛人员</text>
    </view>

    <view class="project-section" wx:if="{{projectConfig.projects.men_singles && projectConfig.projects.men_singles.enabled}}">
      <view class="project-header">
        <view class="project-title-wrapper">
          <text class="project-title">男单</text>
          <text class="project-badge">{{projectConfig.projects.men_singles.count}}人</text>
        </view>
      </view>
      <view class="project-grid" style="--grid-count: {{projectConfig.projects.men_singles.count}};">
        <view class="grid-item" wx:for="{{projectConfig.projects.men_singles.count}}" wx:key="index" wx:for-index="idx">
          <view class="position-badge">{{idx + 1}}号位</view>
          <custom-picker
            placeholder="选择队员"
            options="{{maleMembers}}"
            value="{{projectAssignments.men_singles[idx] ? projectAssignments.men_singles[idx].player_a : ''}}"
            data-project="men_singles"
            data-position="{{idx}}"
            bind:change="onProjectPlayerSelect"
            disabled="{{submitted || !canEdit}}"
          />
        </view>
      </view>
    </view>

    <view class="project-section" wx:if="{{projectConfig.projects.women_singles && projectConfig.projects.women_singles.enabled}}">
      <view class="project-header">
        <view class="project-title-wrapper">
          <text class="project-title">女单</text>
          <text class="project-badge">{{projectConfig.projects.women_singles.count}}人</text>
        </view>
      </view>
      <view class="project-grid" style="--grid-count: {{projectConfig.projects.women_singles.count}};">
        <view class="grid-item" wx:for="{{projectConfig.projects.women_singles.count}}" wx:key="index" wx:for-index="idx">
          <view class="position-badge">{{idx + 1}}号位</view>
          <custom-picker
            placeholder="选择队员"
            options="{{femaleMembers}}"
            value="{{projectAssignments.women_singles[idx] ? projectAssignments.women_singles[idx].player_a : ''}}"
            data-project="women_singles"
            data-position="{{idx}}"
            bind:change="onProjectPlayerSelect"
            disabled="{{submitted || !canEdit}}"
          />
        </view>
      </view>
    </view>

    <view class="project-section" wx:if="{{projectConfig.projects.men_doubles && projectConfig.projects.men_doubles.enabled}}">
      <view class="project-header">
        <view class="project-title-wrapper">
          <text class="project-title">男双</text>
          <text class="project-badge">{{projectConfig.projects.men_doubles.count}}对</text>
        </view>
      </view>
      <view class="doubles-list">
        <view class="doubles-pair" wx:for="{{projectConfig.projects.men_doubles.count}}" wx:key="index" wx:for-index="idx">
          <view class="pair-header">
            <text class="pair-number">第 {{idx + 1}} 对</text>
          </view>
          <view class="pair-grid">
            <view class="pair-item">
              <view class="player-badge">选手A</view>
              <custom-picker
                placeholder="选择队员"
                options="{{maleMembers}}"
                value="{{projectAssignments.men_doubles[idx] ? projectAssignments.men_doubles[idx].player_a : ''}}"
                data-project="men_doubles"
                data-position="{{idx}}"
                data-player="a"
                bind:change="onProjectPlayerSelect"
                disabled="{{submitted || !canEdit}}"
              />
            </view>
            <view class="pair-item">
              <view class="player-badge">选手B</view>
              <custom-picker
                placeholder="选择队员"
                options="{{maleMembers}}"
                value="{{projectAssignments.men_doubles[idx] ? projectAssignments.men_doubles[idx].player_b : ''}}"
                data-project="men_doubles"
                data-position="{{idx}}"
                data-player="b"
                bind:change="onProjectPlayerSelect"
                disabled="{{submitted || !canEdit}}"
              />
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="project-section" wx:if="{{projectConfig.projects.women_doubles && projectConfig.projects.women_doubles.enabled}}">
      <view class="project-header">
        <view class="project-title-wrapper">
          <text class="project-title">女双</text>
          <text class="project-badge">{{projectConfig.projects.women_doubles.count}}对</text>
        </view>
      </view>
      <view class="doubles-list">
        <view class="doubles-pair" wx:for="{{projectConfig.projects.women_doubles.count}}" wx:key="index" wx:for-index="idx">
          <view class="pair-header">
            <text class="pair-number">第 {{idx + 1}} 对</text>
          </view>
          <view class="pair-grid">
            <view class="pair-item">
              <view class="player-badge">选手A</view>
              <custom-picker
                placeholder="选择队员"
                options="{{femaleMembers}}"
                value="{{projectAssignments.women_doubles[idx] ? projectAssignments.women_doubles[idx].player_a : ''}}"
                data-project="women_doubles"
                data-position="{{idx}}"
                data-player="a"
                bind:change="onProjectPlayerSelect"
                disabled="{{submitted || !canEdit}}"
              />
            </view>
            <view class="pair-item">
              <view class="player-badge">选手B</view>
              <custom-picker
                placeholder="选择队员"
                options="{{femaleMembers}}"
                value="{{projectAssignments.women_doubles[idx] ? projectAssignments.women_doubles[idx].player_b : ''}}"
                data-project="women_doubles"
                data-position="{{idx}}"
                data-player="b"
                bind:change="onProjectPlayerSelect"
                disabled="{{submitted || !canEdit}}"
              />
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="project-section" wx:if="{{projectConfig.projects.mixed_doubles && projectConfig.projects.mixed_doubles.enabled}}">
      <view class="project-header">
        <view class="project-title-wrapper">
          <text class="project-title">混双</text>
          <text class="project-badge">{{projectConfig.projects.mixed_doubles.count}}对</text>
        </view>
      </view>
      <view class="doubles-list">
        <view class="doubles-pair" wx:for="{{projectConfig.projects.mixed_doubles.count}}" wx:key="index" wx:for-index="idx">
          <view class="pair-header">
            <text class="pair-number">第 {{idx + 1}} 对</text>
          </view>
          <view class="pair-grid">
            <view class="pair-item">
              <view class="player-badge male">男选手</view>
              <custom-picker
                placeholder="选择队员"
                options="{{maleMembers}}"
                value="{{projectAssignments.mixed_doubles[idx] ? projectAssignments.mixed_doubles[idx].player_a : ''}}"
                data-project="mixed_doubles"
                data-position="{{idx}}"
                data-player="a"
                bind:change="onProjectPlayerSelect"
                disabled="{{submitted || !canEdit}}"
              />
            </view>
            <view class="pair-item">
              <view class="player-badge female">女选手</view>
              <custom-picker
                placeholder="选择队员"
                options="{{femaleMembers}}"
                value="{{projectAssignments.mixed_doubles[idx] ? projectAssignments.mixed_doubles[idx].player_b : ''}}"
                data-project="mixed_doubles"
                data-position="{{idx}}"
                data-player="b"
                bind:change="onProjectPlayerSelect"
                disabled="{{submitted || !canEdit}}"
              />
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-actions">
    <view class="action-row" wx:if="{{canEdit && !submitted}}">
      <button class="secondary-btn" bindtap="onSaveDraft" disabled="{{isSavingDraft || isSubmitting}}">
        {{isSavingDraft ? '保存中...' : '保存队伍信息'}}
      </button>
      <button class="submit-btn" bindtap="onSubmit" disabled="{{isSubmitting || isSavingDraft}}">
        {{isSubmitting ? '提交中...' : '正式提交报名'}}
      </button>
    </view>

    <view class="action-row" wx:elif="{{canEdit}}">
      <button class="submit-btn" disabled="true">队伍已正式提交</button>
      <button class="secondary-btn" bindtap="onGoBack">返回</button>
    </view>
    <view class="action-row" wx:else>
      <button class="submit-btn" disabled="true">仅可查看队伍信息</button>
      <button class="secondary-btn" bindtap="onGoBack">返回</button>
    </view>
  </view>
</view>

<view class="loading" wx:elif="{{isLoading}}">
  <text>加载中...</text>
</view>
