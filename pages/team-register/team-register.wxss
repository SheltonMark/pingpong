.register-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 220rpx;
  box-sizing: border-box;
}

.event-card,
.team-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.05);
}

.event-card {
  padding: 32rpx;
}

.event-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.event-info,
.event-rule {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 32rpx 32rpx 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.card-subtitle {
  font-size: 22rpx;
  color: #9ca3af;
}

.status-tag {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-tag.draft {
  color: #b45309;
  background: #fffbeb;
}

.status-tag.submitted {
  color: #047857;
  background: #ecfdf5;
}

.form-row {
  padding: 0 32rpx 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
}

.form-tip {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.team-name-input {
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f9fafb;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  padding: 8rpx 32rpx 32rpx;
}

.summary-item {
  background: #f9fafb;
  border-radius: 20rpx;
  padding: 24rpx;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 12rpx;
}

.summary-value {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.member-list,
.pending-list {
  padding: 0 24rpx 24rpx;
}

.member-item,
.pending-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f9fafb;
  transition: all 0.3s;
}

.member-item + .member-item,
.pending-item + .pending-item {
  margin-top: 16rpx;
}

.member-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #e5e7eb;
  flex-shrink: 0;
}

.member-main,
.pending-main {
  flex: 1;
  min-width: 0;
}

.member-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.member-name,
.pending-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-left: 9rpx;
}

.member-info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: nowrap;
  overflow: hidden;
}

.member-info-item {
  font-size: 24rpx;
  color: #6b7280;
  padding: 4rpx 12rpx;
  background: #fff;
  border-radius: 8rpx;
}

.project-tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
}

.project-tag.men-singles,
.project-tag.men-doubles {
  color: #1d4ed8;
  background: #dbeafe;
}

.project-tag.women-singles,
.project-tag.women-doubles {
  color: #be185d;
  background: #fce7f3;
}

.project-tag.mixed-doubles {
  color: #7c3aed;
  background: #ede9fe;
}

.member-meta,
.pending-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.5;
}

.member-actions,
.pending-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.mini-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  line-height: 1.4;
}

.mini-tag.leader {
  color: #1d4ed8;
  background: #dbeafe;
}

.mini-tag.muted {
  color: #6b7280;
  background: #f3f4f6;
}

.mini-tag.warning {
  color: #b91c1c;
  background: #fee2e2;
}

.mini-tag.singles {
  color: #b45309;
  background: #fffbeb;
}

.text-btn,
.small-btn,
.invite-create-btn,
.submit-btn,
.secondary-btn {
  border: none;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0;
}

.text-btn,
.small-btn {
  min-width: 136rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff7ed;
  color: #ea580c;
}

.text-btn::after,
.small-btn::after,
.invite-create-btn::after,
.submit-btn::after,
.secondary-btn::after {
  border: none;
}

.text-btn.danger,
.small-btn.danger {
  background: #fee2e2;
  color: #b91c1c;
}

.invite-panel {
  padding: 0 32rpx 32rpx;
}

.invite-tip {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.invite-create-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff8a00, #ff6b00);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-tip,
.loading {
  text-align: center;
  padding: 48rpx 32rpx;
  font-size: 26rpx;
  color: #9ca3af;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(15, 23, 42, 0.08);
  z-index: 100;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.submit-btn,
.secondary-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #ff8a00, #ff6b00);
  color: #ffffff;
}

.secondary-btn {
  background: #f3f4f6;
  color: #4b5563;
}

.invite-create-btn[disabled],
.submit-btn[disabled],
.secondary-btn[disabled],
.text-btn[disabled],
.small-btn[disabled] {
  opacity: 0.45;
}

/* 项目分配样式 */
.project-section {
  padding: 24rpx 32rpx 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.project-section:last-child {
  border-bottom: none;
}

.project-header {
  margin-bottom: 24rpx;
}

.project-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.project-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: 0.5rpx;
}

.project-badge {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  background: linear-gradient(135deg, #ff8a00 0%, #ff6b00 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  letter-spacing: 0.5rpx;
}

/* 单打项目 Grid 布局 */
.project-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

/* 如果只有1个位置，占满整行 */
.project-grid[style*="--grid-count: 1"] {
  grid-template-columns: 1fr;
}

.grid-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.position-badge {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  padding-left: 4rpx;
}

/* 双打项目列表 */
.doubles-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.doubles-pair {
  background: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.pair-header {
  margin-bottom: 16rpx;
}

.pair-number {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: 0.5rpx;
}

.pair-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.pair-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.player-badge {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  padding-left: 4rpx;
}

.player-badge.male {
  color: #1d4ed8;
}

.player-badge.female {
  color: #be185d;
}

