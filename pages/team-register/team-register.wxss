.register-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 220rpx;
}

.event-card,
.team-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 32rpx;
}

.event-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.event-info {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.card-header {
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.card-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.team-name-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-row {
  margin-top: 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-label {
  font-size: 26rpx;
  color: #666;
}

/* 邀请队友 */
.invite-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.invite-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.invite-icon {
  font-size: 32rpx;
}

.invite-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.invite-btn {
  flex-shrink: 0;
  padding: 16rpx 48rpx;
  background: #FF6B00;
  color: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
}

.invite-btn.disabled {
  background: #e5e5e5;
  color: #999;
}

/* 队员列表 */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.member-item.selected {
  background: #e6f4ff;
  border: 2rpx solid #1890ff;
}

.member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.leader-tag {
  padding: 4rpx 12rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.member-meta {
  font-size: 22rpx;
  color: #999;
}

.member-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 12rpx 24rpx;
  background: #fff;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1;
}

.action-btn.danger {
  color: #ff4d4f;
  border-color: #ff4d4f;
}

/* 待处理邀请 */
.pending-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pending-item {
  padding: 24rpx;
  background: #fffbe6;
  border-radius: 12rpx;
  border: 2rpx solid #ffe58f;
}

.pending-main {
  margin-bottom: 16rpx;
}

.pending-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.pending-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.pending-actions {
  display: flex;
  gap: 16rpx;
}

.small-btn {
  flex: 1;
  padding: 16rpx;
  background: #fff;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1;
}

.small-btn.danger {
  color: #ff4d4f;
  border-color: #ff4d4f;
}

.empty-tip {
  padding: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  border-top: 2rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-row {
  display: flex;
  gap: 24rpx;
}

.secondary-btn,
.primary-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 88rpx;
}

.secondary-btn {
  background: #f5f5f5;
  color: #666;
}

.primary-btn {
  background: #FF6B00;
  color: #fff;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 88rpx;
}

button[disabled] {
  opacity: 0.5;
}
