.register-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  padding-bottom: 220rpx;
}

.event-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.event-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
}

.event-info {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-top: 12rpx;
  display: block;
}

.team-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-header {
  padding: 36rpx;
  border-bottom: 1rpx solid #F0F0F0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.card-subtitle {
  font-size: 22rpx;
  color: #9CA3AF;
}

.team-name-input {
  width: 100%;
  height: 100rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
  line-height: 100rpx;
  color: #1A1A1A;
  box-sizing: border-box;
}

.leader-setting {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 36rpx 20rpx;
}

.leader-setting-label {
  font-size: 24rpx;
  color: #6B7280;
}

.leader-setting-value {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-height: 44rpx;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 20rpx;
  border-radius: 999rpx;
  line-height: 1.2;
  white-space: nowrap;
  box-sizing: border-box;
}

.leader-setting-value.on {
  background: #ECFDF5;
  color: #047857;
}

.leader-setting-value.off {
  background: #FEF2F2;
  color: #B91C1C;
}

.leader-setting-tip {
  display: block;
  padding: 0 36rpx 24rpx;
  font-size: 22rpx;
  color: #B45309;
}

.team-list {
  padding: 0 36rpx 36rpx;
}

.team-slot {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 24rpx;
  margin-top: 20rpx;
  transition: background 0.2s;
}

.team-slot.confirmed {
  background: #ECFDF5;
}

.team-slot.empty {
  border: 4rpx dashed #D1D5DB;
  background: transparent;
}

/* 单打标记状态 */
.team-slot.singles-marked {
  background: #FEF3C7 !important;
  border: 2rpx solid #F59E0B;
}

.slot-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.slot-avatar-empty {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

.slot-info {
  flex: 1;
  margin-left: 24rpx;
}

.slot-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
}

.slot-position {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
  display: block;
}

.slot-position-empty {
  font-size: 28rpx;
  font-weight: 500;
  color: #9CA3AF;
}

.slot-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.singles-tag {
  font-size: 22rpx;
  font-weight: 600;
  color: #D97706;
  background: #FEF3C7;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #F59E0B;
}

.not-playing-tag {
  font-size: 22rpx;
  font-weight: 600;
  color: #B91C1C;
  background: #FEE2E2;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #FCA5A5;
}

/* 分享邀请按钮（覆盖微信button默认样式） */
.invite-btn {
  padding: 12rpx 24rpx;
  background: #FF6B00;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
  border-radius: 16rpx;
  line-height: 1.5;
  margin: 0;
}

.invite-btn::after {
  border: none;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.action-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.submit-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B00, #E55D00);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.35);
  padding: 0;
}

.secondary-btn,
.danger-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.secondary-btn {
  background: #F3F4F6;
  color: #4B5563;
}

.danger-btn {
  background: #FEE2E2;
  color: #B91C1C;
}

.submit-btn[disabled] {
  opacity: 0.5;
}

.secondary-btn[disabled],
.danger-btn[disabled] {
  opacity: 0.5;
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: #9CA3AF;
  font-size: 26rpx;
}

.loading {
  text-align: center;
  padding: 60rpx;
  font-size: 28rpx;
  color: #9CA3AF;
}
